{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "preserve"
  },
  "include": [
    "**/*.tsx",
    "**/*.d.ts"
  ],
  "exclude": [
    "vite.config.ts"
  ]
}

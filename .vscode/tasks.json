  "inputs": [
    {
      "id": "geaEmbeddedExample",
      "type": "pickString",
      "description": "ESP32-enabled example to build/deploy",
      "options": [
        "app-launcher",
        "bouncing-balls",
        "image-demo",
        "analog-clock",
        "static-card",
        "typography",
        "tilt-breakout",
        "button-tetris",
        "tic-tac-toe",
        "bouncing-balls-jsx",
        "hid-clicker",
        "sky-hop",
        "sky-hop-jsx"
      ],
      "default": "app-launcher"
    },
    {
      "id": "geaEmbeddedSerialPort",
      "type": "promptString",
      "description": "USB serial port, or auto to let ESP-IDF detect it.",
      "default": "auto"
    },
    {
      "id": "geaEmbeddedInstallApp",
      "type": "pickString",
      "description": "App to install into the launcher",
      "options": [
        "bouncing-balls",
        "image-demo",
        "analog-clock",
        "static-card",
        "typography",
        "tilt-breakout",
        "button-tetris",
        "tic-tac-toe",
        "bouncing-balls-jsx",
        "hid-clicker",
        "sky-hop",
        "sky-hop-jsx"
      ],
      "default": "button-tetris"
    },
    {

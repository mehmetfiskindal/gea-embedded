      "options": [
        "bouncing-balls",
        "image-demo",
        "analog-clock",
        "static-card",
        "typography",
        "tilt-breakout",
        "button-tetris",
        "tic-tac-toe",
        "bouncing-balls-jsx",
        "hid-clicker",
        "sky-hop",
        "sky-hop-jsx"
      ],
      "default": "button-tetris"
    },
    {
      "id": "geaEmbeddedBoardIp",
      "type": "promptString",
      "description": "Board IP address for WiFi OTA deploy",
      "default": ""
    }
